<!-- Zoom Styles -->
<style>
.zoom-container {
  position: relative;
  display: inline-block;
  overflow: hidden;
  border: 1px solid #ddd;
}

.zoom-lens {
  position: absolute;
  border: 1px solid #333;
  background: rgba(255, 255, 255, 0.4);
  width: 200px;
  height: 200px;
  pointer-events: none;
  display: none;
  cursor: zoom-in;
}

#mainImage.zoomed {
  transform-origin: 0 0;
  transition: transform 0.1s ease;
}
</style>

