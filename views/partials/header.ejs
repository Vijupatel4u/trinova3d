<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>TriNova3D -Where Vision Becomes Dimension</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
  <style>
    :root {
      --primary: #6b48ff;
      --primary-dark: #5439cc;
      --secondary: #ff6b6b;
      --dark: #1a1a2e;
      --light: #f8f9fa;
    }
    body {
      font-family: 'Poppins', sans-serif;
      background: linear-gradient(135deg, var(--light) 0%, #e0e7ff 100%);
      color: var(--dark);
    }
    .navbar {
      background: rgba(255, 255, 255, 0.95);
      backdrop-filter: blur(10px);
      box-shadow: 0 4px 30px rgba(0,0,0,0.1);
      border-bottom: 1px solid rgba(107,72,255,0.1);
      padding: 0.8rem 0;
    }
    .navbar-brand {
      font-weight: 700;
      font-family: 'Playfair Display', serif;
      color: var(--primary);
      font-size: 1.6rem;
    }
    .nav-link {
      color: var(--dark);
      font-weight: 500;
      transition: color 0.3s;
    }
    .nav-link:hover {
      color: var(--primary);
    }
    .cart-icon-wrapper {
      position: relative;
    }
    .cart-badge {
      position: absolute;
      top: -8px;
      right: -8px;
      background: var(--secondary);
      color: white;
      font-size: 0.7rem;
      width: 18px;
      height: 18px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
    }
  </style>
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-light bg-light fixed-top">
    <div class="container">
      <a class="navbar-brand" href="/">TriNova3D</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav ms-auto align-items-center">
          <li class="nav-item">
            <a class="nav-link" href="/">Home</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/about">About Us</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/contact">Contact Us</a>
          </li>

          <li class="nav-item me-2">
            <a class="nav-link cart-icon-wrapper" href="/cart" id="cart-icon">
              <i class="fas fa-shopping-cart fa-lg"></i>
              <% if (cartCount > 0) { %>
                <span class="cart-badge" id="cart-count"><%= cartCount %></span>
              <% } %>
            </a>
          </li>

          <% if (user) { %>
            <% if (user.role === 'admin') { %>
              <li class="nav-item">
                <a class="btn btn-sm btn-outline-primary ms-2" href="/admin/dashboard">Admin</a>
              </li>
            <% } %>
            <li class="nav-item">
              <a class="btn btn-sm btn-danger ms-2" href="/logout">Logout</a>
            </li>
          <% } else { %>
            <li class="nav-item"><a class="btn btn-sm btn-outline-primary ms-3" href="/login">Login</a></li>
            <li class="nav-item"><a class="btn btn-sm btn-primary ms-2" href="/register">Register</a></li>
          <% } %>
        </ul>
      </div>
    </div>
  </nav>

  <div style="height: 90px;"></div>
</body>
</html>