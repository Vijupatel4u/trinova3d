<%- include('../partials/header', { user: user }) %>

<div class="container my-5">
  <h2 class="text-center mb-4">🛠️ Admin Dashboard - Welcome, <%= user.name %>!</h2>

  <!-- Success / Error Messages -->
  <% if (error) { %>
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
      <%= error %>
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
  <% } %>
  <% if (success) { %>
    <div class="alert alert-success alert-dismissible fade show" role="alert">
      <%= success %>
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
  <% } %>

  <!-- Add New Category -->
  <div class="card p-4 shadow mb-5">
    <h4 class="mb-3">Add New Category</h4>
    <form action="/admin/add-category" method="POST">
      <div class="input-group">
        <input type="text" name="name" class="form-control" placeholder="New category name" required>
        <button type="submit" class="btn btn-primary">Add Category</button>
      </div>
    </form>
  </div>

  <!-- Add New Product -->
  <div class="card p-4 shadow mb-5">
    <h4 class="mb-3">Add New Product</h4>
    <form action="/admin/add-product" method="POST" enctype="multipart/form-data">
      <div class="row g-3">
        <div class="col-md-6">
          <label class="form-label">Product Name</label>
          <input type="text" name="name" class="form-control" required>
        </div>
        <div class="col-md-6">
          <label class="form-label">Price (₹)</label>
          <input type="number" name="price" class="form-control" step="0.01" required>
        </div>
        <div class="col-md-6">
          <label class="form-label">Category</label>
          <select name="category" class="form-select" required>
            <option value="">Select Category</option>
            <% categories.forEach(cat => { %>
              <option value="<%= cat._id %>"><%= cat.name %></option>
            <% }) %>
          </select>
        </div>
        <div class="col-12">
          <label class="form-label">Description</label>
          <textarea name="description" class="form-control" rows="3" required></textarea>
        </div>
        <div class="col-12">
          <label class="form-label">Images (multiple - up to 10)</label>
          <input type="file" name="images" class="form-control" multiple accept="image/*">
          <small class="text-muted">Select multiple images at once</small>
        </div>
        <div class="col-12">
          <button type="submit" class="btn btn-success">Add Product</button>
        </div>
      </div>
    </form>
  </div>

  <!-- Manage Slideshow Images -->
  <div class="card p-4 shadow mb-5">
    <h4 class="mb-4">Manage Slideshow Images (Home Page Banner)</h4>

    <form action="/admin/add-slideshow" method="POST" enctype="multipart/form-data">
      <div class="row g-3 align-items-end">
        <div class="col-md-5">
          <label class="form-label">Add New Slideshow Image</label>
          <input type="file" name="slideshowImage" class="form-control" accept="image/*" required>
          <small class="text-muted">Recommended size: 1920×800 or similar wide banner</small>
        </div>
        <div class="col-md-5">
          <label class="form-label">Caption (optional)</label>
          <input type="text" name="caption" class="form-control" placeholder="e.g. Handcrafted Frames from Surat">
        </div>
        <div class="col-md-2">
          <button type="submit" class="btn btn-primary w-100">Add Image</button>
        </div>
      </div>
    </form>

    <h5 class="mt-5 mb-3">Current Slideshow Images</h5>

    <% if (slideshowImages && slideshowImages.length > 0) { %>
      <div class="row">
        <% slideshowImages.forEach((img) => { %>
          <div class="col-md-4 col-lg-3 mb-4">
            <div class="card h-100 shadow-sm">
              <img src="<%= img.imageUrl %>" class="card-img-top" alt="Slide" style="height: 160px; object-fit: cover;">
              <div class="card-body text-center">
                <p class="card-text small mb-2">
                  <% if (img.caption && img.caption.trim() !== 'Dola Art Corner') { %>
                    <strong><%= img.caption %></strong>
                  <% } else { %>
                    <em>No caption</em>
                  <% } %>
                </p>
                <p class="text-muted small mb-2">
                  Added: <%= new Date(img.createdAt).toLocaleDateString('en-IN') %>
                </p>

                <form action="/admin/delete-slideshow/<%= img._id %>" method="POST" style="display:inline;"
                      onsubmit="return confirm('Delete this slideshow image?');">
                  <button type="submit" class="btn btn-danger btn-sm">
                    <i class="fas fa-trash"></i> Delete
                  </button>
                </form>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <div class="alert alert-info mt-3">
        No slideshow images uploaded yet.
      </div>
    <% } %>
  </div>

  <!-- Products List -->
  <h3 class="mb-4">Your Products</h3>
  <% if (products && products.length > 0) { %>
    <div class="row">
      <% products.forEach(product => { %>
        <div class="col-md-4 mb-4">
          <div class="card h-100 shadow">
            <% if (product.images && product.images.length > 0) { %>
              <img src="<%= product.images[0] %>" class="card-img-top" alt="<%= product.name %>" style="height: 200px; object-fit: cover;">
            <% } else { %>
              <img src="https://via.placeholder.com/300x200?text=No+Image" class="card-img-top" style="height: 200px; object-fit: cover;">
            <% } %>
            <div class="card-body">
              <h5 class="card-title"><%= product.name %></h5>
              <p class="card-text text-muted"><%= product.description.substring(0, 80) %>...</p>
              <p class="fw-bold">₹<%= product.price %></p>
              <p class="text-muted small">
  Category: <%= product.category && product.category.name ? product.category.name : 'Uncategorized' %>
</p>
              <div class="mt-3">
                <a href="/admin/edit-product/<%= product._id %>" class="btn btn-warning btn-sm me-2">
                  <i class="fas fa-edit"></i> Edit
                </a>
                <form action="/admin/delete-product/<%= product._id %>" method="POST" style="display:inline;" 
                      onsubmit="return confirm('Delete <%= product.name %>?');">
                  <button type="submit" class="btn btn-danger btn-sm" title="Delete Product">
                    <i class="fas fa-trash"></i>
                  </button>
                </form>
              </div>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } else { %>
    <p>No products yet. Add one above!</p>
  <% } %>

  <!-- Categories List -->
  <h3 class="mb-4 mt-5">Categories</h3>
  <% if (categories && categories.length > 0) { %>
    <div class="row">
      <% categories.forEach(cat => { %>
        <div class="col-md-4 mb-4">
          <div class="card h-100 shadow">
            <div class="card-body">
              <h5 class="card-title"><%= cat.name %></h5>
              <div class="mt-3 d-flex flex-wrap gap-2 align-items-center">
                <form action="/admin/edit-category/<%= cat._id %>" method="POST" class="d-flex gap-2 flex-grow-1">
                  <input type="text" name="name" class="form-control form-control-sm" value="<%= cat.name %>" required>
                  <button type="submit" class="btn btn-warning btn-sm">
                    <i class="fas fa-save"></i> Save
                  </button>
                </form>

                <form action="/admin/delete-category/<%= cat._id %>" method="POST" style="display:inline;" 
                      onsubmit="return confirm('Delete <%= cat.name %>? Only if no products attached');">
                  <button type="submit" class="btn btn-danger btn-sm" title="Delete Category">
                    <i class="fas fa-trash"></i>
                  </button>
                </form>
              </div>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } else { %>
    <p>No categories yet. Add one above!</p>
  <% } %>

</div>

<%- include('../partials/footer') %>