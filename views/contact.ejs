<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Contact Us - Trinova3D</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
  <style>
    :root {
      --primary: #6b48ff;
      --primary-dark: #5439cc;
      --secondary: #ff6b6b;
      --dark: #1a1a2e;
      --light: #f8f9fa;
    }
    body {
      font-family: 'Poppins', sans-serif;
      background: linear-gradient(135deg, var(--light) 0%, #e0e7ff 100%);
      color: var(--dark);
    }
    .navbar {
      background: rgba(255, 255, 255, 0.95);
      backdrop-filter: blur(10px);
      box-shadow: 0 4px 30px rgba(0,0,0,0.1);
      border-bottom: 1px solid rgba(107,72,255,0.1);
      padding: 0.8rem 0;
    }
    .navbar-brand {
      font-weight: 700;
      font-family: 'Playfair Display', serif;
      color: var(--primary);
      font-size: 1.6rem;
    }
    .nav-link {
      color: var(--dark);
      font-weight: 500;
      transition: color 0.3s;
    }
    .nav-link:hover {
      color: var(--primary);
    }
    .cart-icon-wrapper {
      position: relative;
    }
    .cart-badge {
      position: absolute;
      top: -8px;
      right: -8px;
      background: var(--secondary);
      color: white;
      font-size: 0.7rem;
      width: 18px;
      height: 18px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
    }
  </style>
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-light bg-light fixed-top">
    <div class="container">
      <a class="navbar-brand" href="/">TriNova3D</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav ms-auto align-items-center">
          <li class="nav-item">
            <a class="nav-link" href="/">Home</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/about">About Us</a>
          </li>
          <li class="nav-item">
            <a class="nav-link active" href="/contact">Contact Us</a>
          </li>

          <li class="nav-item me-2">
            <a class="nav-link cart-icon-wrapper" href="/cart" id="cart-icon">
              <i class="fas fa-shopping-cart fa-lg"></i>
              <% if (cartCount > 0) { %>
                <span class="cart-badge" id="cart-count"><%= cartCount %></span>
              <% } %>
            </a>
          </li>

          <% if (user) { %>
            <% if (user.role === 'admin') { %>
              <li class="nav-item">
                <a class="btn btn-sm btn-outline-primary ms-2" href="/admin/dashboard">Admin</a>
              </li>
            <% } %>
            <li class="nav-item">
              <a class="btn btn-sm btn-danger ms-2" href="/logout">Logout</a>
            </li>
          <% } else { %>
            <li class="nav-item"><a class="btn btn-sm btn-outline-primary ms-3" href="/login">Login</a></li>
            <li class="nav-item"><a class="btn btn-sm btn-primary ms-2" href="/register">Register</a></li>
          <% } %>
        </ul>
      </div>
    </div>
  </nav>

  <div style="height: 90px;"></div>

  <div class="container my-5">
    <h2 class="text-center mb-5 fw-bold">Contact Us</h2>

    <div class="row justify-content-center">
      <div class="col-lg-8">
        <div class="card shadow-lg border-0">
          <div class="card-body p-5">
            <h4 class="text-center mb-4">Trinova3D</h4>

            <!-- Shop Info -->
            <div class="text-center mb-5">
              <p class="mb-2"><strong>Email:</strong>info.trinova3d@gmail.com</p>
              <p class="mb-3"><strong>WhatsApp:</strong> +91 63519 01228</p>
              <p class="text-muted">Please feel free to submit form for any Enquiry. We'll contact as soon as possible!</p>
            </div>

            <!-- Form -->
            <form action="/contact/send" method="POST">
              <div class="mb-3">
                <label class="form-label fw-bold">Your Name <span class="text-danger">*</span></label>
                <input type="text" name="name" class="form-control" required>
              </div>

              <div class="mb-3">
                <label class="form-label fw-bold">Email Address (optional)</label>
                <input type="email" name="email" class="form-control">
              </div>

              <div class="mb-3">
                <label class="form-label fw-bold">Subject (optional)</label>
                <input type="text" name="subject" class="form-control">
              </div>

              <div class="mb-4">
                <label class="form-label fw-bold">Your Message <span class="text-danger">*</span></label>
                <textarea name="message" class="form-control" rows="5" required></textarea>
              </div>

              <button type="submit" class="btn btn-success btn-lg w-100">
                <i class="fab fa-whatsapp me-2"></i> Send via WhatsApp
              </button>
            </form>

            <!-- Messages -->
            <% if (success) { %>
              <div class="alert alert-success mt-4 text-center">
                <%= success %>
              </div>
            <% } %>
            <% if (error) { %>
              <div class="alert alert-danger mt-4 text-center">
                <%= error %>
              </div>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </div>

   <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<%- include('partials/footer') %>
  </body>
</html>